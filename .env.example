MT_NODE_PORT=43110
MT_NODE_HOST=0.0.0.0
MT_NODE_DATA_DIR=./data
MT_NODE_TUNNEL_MODE=binary
MT_NODE_TUNNEL_BIN=cloudflared
MT_NODE_TUNNEL_TIMEOUT_MS=30000
MT_NODE_PEER_DELIVERY_MODE=assist
# Legacy boolean toggle. Prefer MT_NODE_PEER_DELIVERY_MODE instead.
# MT_NODE_WEBTORRENT_ENABLED=1
# Comma-separated tracker list. Defaults to public WebTorrent-compatible WSS trackers.
# MT_NODE_WEBTORRENT_TRACKERS=
# Optional guardrails for always-on seeding.
# MT_NODE_PEER_DELIVERY_MAX_ACTIVE_TORRENTS=
# MT_NODE_PEER_DELIVERY_MAX_CONNECTIONS=
# Leave as 0 to let the OS choose open ports automatically.
# MT_NODE_WEBTORRENT_PORT=0
# MT_NODE_WEBTORRENT_DHT_PORT=0
# Default inbox: ~/MachineTube/videos or %USERPROFILE%\\MachineTube\\videos
# MT_NODE_INBOX_DIR=
# Override only when needed. Defaults depend on tunnel mode.
# MT_NODE_TUNNEL_TARGET_URL=
# MT_NODE_PUBLIC_BASE_URL=
# MT_MACHINETUBE_BASE_URL=
# MT_MACHINETUBE_AGENT_ID=
# MT_MACHINETUBE_API_KEY=
